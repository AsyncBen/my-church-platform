datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  MEMBER
  MEDIA
  PASTOR
  SECRETARY
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum ServiceState {
  OFFLINE
  PREPARING
  LIVE
  PAUSED
  ENDED
}

enum SermonStatus {
  DRAFT
  READY
  DELIVERED
}

enum AnnouncementCategory {
  GENERAL
  EVENT
  EMERGENCY
  PRAYER
  OFFERING
}

enum GivingType {
  TITHE
  OFFERING
  THANKSGIVING
  BUILDING_FUND
  MISSION_SUPPORT
  SPECIAL_SEED
}

enum GivingStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum FeedPostType {
  ANNOUNCEMENT
  DEVOTIONAL
  SERMON
  TESTIMONY
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  name          String?
  phone         String?
  gender        String?
  ministry      String?
  role          Role          @default(MEMBER)
  status        UserStatus    @default(ACTIVE)
  requestedRole Role?
  givings       Giving[]
  prayers       Prayer[]
  feedPosts     FeedPost[]
  feedComments  FeedComment[]
  feedLikes     FeedLike[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model LiveService {
  id               String       @id @default(uuid())
  currentScripture String?
  sermonTitle      String?
  state            ServiceState @default(OFFLINE)
  startedAt        DateTime?
  updatedAt        DateTime     @updatedAt
  sermon           Sermon?      @relation(fields: [sermonId], references: [id])
  sermonId         String?      @unique
}

model Sermon {
  id            String       @id @default(uuid())
  title         String
  description   String?
  status        SermonStatus @default(DRAFT)
  scriptureList Json?
  queue         Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  liveService   LiveService?
}

model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  category    AnnouncementCategory @default(GENERAL)
  isLive      Boolean              @default(false)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime             @default(now())
}

model Giving {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  category  GivingType
  amount    Float
  reference String?
  note      String?
  service   String
  status    GivingStatus  @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Event {
  id        String   @id @default(uuid())
  title     String
  date      String
  time      String
  type      String
  accent    String   @default("#1B3A7A")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prayer {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  text        String
  category    String   @default("Personal")
  isAnonymous Boolean  @default(false)
  prayerCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeedPost {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  type          FeedPostType
  title         String
  body          String
  imageUrl      String?
  likesCount    Int           @default(0)
  commentsCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  comments      FeedComment[]
  likes         FeedLike[]
}

model FeedComment {
  id        String   @id @default(uuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model FeedLike {
  id        String   @id @default(uuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}