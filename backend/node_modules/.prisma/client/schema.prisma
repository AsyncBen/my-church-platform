datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  MEMBER
  MEDIA
  PASTOR
  SECRETARY
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum ServiceState {
  OFFLINE
  PREPARING
  LIVE
  PAUSED
  ENDED
}

enum SermonStatus {
  DRAFT
  READY
  DELIVERED
}

enum AnnouncementCategory {
  GENERAL
  EVENT
  EMERGENCY
  PRAYER
  OFFERING
}

enum GivingType {
  TITHE
  OFFERING
  THANKSGIVING
  BUILDING_FUND
  MISSION_SUPPORT
  SPECIAL_SEED
}

enum GivingStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  name          String?
  phone         String?
  gender        String?
  ministry      String?
  role          Role       @default(MEMBER)
  status        UserStatus @default(ACTIVE)
  requestedRole Role?
  givings       Giving[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model LiveService {
  id               String       @id @default(uuid())
  currentScripture String?
  sermonTitle      String?
  state            ServiceState @default(OFFLINE)
  startedAt        DateTime?
  updatedAt        DateTime     @updatedAt
  sermon           Sermon?      @relation(fields: [sermonId], references: [id])
  sermonId         String?      @unique
}

model Sermon {
  id            String       @id @default(uuid())
  title         String
  description   String?
  status        SermonStatus @default(DRAFT)
  scriptureList Json?
  queue         Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  liveService   LiveService?
}

model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  category    AnnouncementCategory @default(GENERAL)
  isLive      Boolean              @default(false)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime             @default(now())
}

model Giving {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  category  GivingType
  amount    Float
  reference String?
  note      String?
  service   String
  status    GivingStatus @default(CONFIRMED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Event {
  id        String   @id @default(uuid())
  title     String
  date      String
  time      String
  type      String
  accent    String   @default("#1B3A7A")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
